# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key   # Never expose to browser
SUPABASE_AUTH_CAPTCHA_SECRET=your_turnstile_secret_key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ALLOWED_ORIGINS=http://localhost:3000

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Abuse protection
UPSTASH_REDIS_REST_URL=https://your-upstash-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
ENABLE_PUSH_TEST_ENDPOINT=false

# Resend (email)
RESEND_API_KEY=re_...                       # From resend.com → API Keys
RESEND_WEBHOOK_SECRET=whsec_...             # Optional — from Resend webhook dashboard (enables svix signature verification)

# Cron security
CRON_SECRET=your_random_secret_string       # Sent as "Authorization: Bearer <secret>" by Vercel Cron
