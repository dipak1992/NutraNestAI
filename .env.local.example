# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key   # Never expose to browser
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Resend (email)
RESEND_API_KEY=re_...                       # From resend.com → API Keys
RESEND_WEBHOOK_SECRET=whsec_...             # Optional — from Resend webhook dashboard (enables svix signature verification)

# Cron security
CRON_SECRET=your_random_secret_string       # Sent as "Authorization: Bearer <secret>" by Vercel Cron
