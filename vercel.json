{
  "framework": "nextjs",
  "functions": {
    "app/api/generate-plan/route.ts": {
      "maxDuration": 60
    },
    "app/api/analyze-image/route.ts": {
      "maxDuration": 30
    },
    "app/api/smart-meal/route.ts": {
      "maxDuration": 30
    },
    "app/api/weekly-plan/route.ts": {
      "maxDuration": 60
    },
    "app/api/regenerate-meal/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/email/reminders?type=dinner",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/email/reminders?type=weekly",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/email/reminders?type=admin-summary",
      "schedule": "0 10 * * 1"
    }
  ]
}
