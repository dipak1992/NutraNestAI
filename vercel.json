    "app/api/smart-meal/route.ts": {
      "maxDuration": 30
    },
    "app/api/scan/classify/route.ts": {
      "maxDuration": 30
    },
    "app/api/scan/fridge/route.ts": {
      "maxDuration": 45
    },
    "app/api/scan/menu/route.ts": {
      "maxDuration": 45
    },
